{
  "expo": {
    "name": "Nutri Lu",
    "slug": "nutri-lu",
    "version": "0.1.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "ios": {
      "bundleIdentifier": "com.nutrilu.app",
      "buildNumber": "1",
      "supportsTablet": false,
      "infoPlist": {
        "NSCameraUsageDescription": "Precisamos da câmera para fotografar suas receitas e pratos.",
        "NSPhotoLibraryUsageDescription": "Precisamos acessar suas fotos para importar receitas e pratos.",
        "NSMicrophoneUsageDescription": "Precisamos do microfone para você registrar refeições por voz.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.nutrilu.app",
      "versionCode": 1,
      "adaptiveIcon": {
        "backgroundColor": "#F6F6F6",
        "foregroundImage": "./assets/android-icon-foreground.png"
      },
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.RECORD_AUDIO",
        "android.permission.MODIFY_AUDIO_SETTINGS"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-font",
      [
        "expo-camera",
        {
          "cameraPermission": "Permita acesso à câmera para fotografar suas receitas."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Permita acesso à galeria para importar receitas e pratos."
        }
      ],
      "expo-audio",
      [
        "expo-splash-screen",
        {
          "image": "./assets/splash-icon.png",
          "imageWidth": 220,
          "resizeMode": "contain",
          "backgroundColor": "#F6F6F6"
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "6017de17-3dab-4593-99f1-497a3763b78b"
      }
    },
    "owner": "raphaeldrs",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/6017de17-3dab-4593-99f1-497a3763b78b"
    }
  }
}
