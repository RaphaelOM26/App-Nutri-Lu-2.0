# Copie este arquivo para `.env` (que está no .gitignore).
# Vars que começam com EXPO_PUBLIC_ são inlinadas no bundle e ficam
# acessíveis em runtime via process.env.EXPO_PUBLIC_*

# URL do backend Express.
# IMPORTANTE: para o Expo Go alcançar seu backend rodando no PC, use o IP
# local da sua máquina na rede Wi-Fi (NÃO localhost, que apontaria para o
# próprio celular).
#
# Para descobrir o IP no Windows: rode `ipconfig` no PowerShell e procure
# por "Endereço IPv4" do adaptador Wi-Fi.
#
# Detectado nesta máquina:
EXPO_PUBLIC_API_URL=http://192.168.1.13:3001
