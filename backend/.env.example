# Copie este arquivo para `.env` e preencha os valores reais.
# Nunca comite `.env` — só `.env.example`.

# Chave da API OpenAI (https://platform.openai.com/api-keys)
OPENAI_API_KEY=sk-...

# Modelo a usar. Default: gpt-5.4-mini (custo: ~$0,75/1M input · ~$4,50/1M output).
# Outras opções: gpt-5.4-nano (mais barato, qualidade menor) · gpt-5.4 (premium).
OPENAI_MODEL=gpt-5.4-mini

# Porta do servidor Express (default 3001).
PORT=3001

# CORS — origins permitidas. Em dev, deixe * para o Expo Go acessar.
# Em produção, restrinja para o domínio do app.
CORS_ORIGIN=*
